{
  "mission": "Mission Control only",
  "phase": "phase1",
  "heartbeat": {
    "enabled": true,
    "intervalMinutes": 30,
    "sessionTarget": "main",
    "wakeMode": "now",
    "message": "Read HEARTBEAT.md and execute only Mission Control work. If concrete progress exists, respond in format: Task / Changed files / What changed / Why it helps / Next. If no concrete progress exists, reply HEARTBEAT_OK."
  },
  "openclawCron": {
    "storePath": "~/.openclaw/cron/jobs.json",
    "sourceOfTruth": true,
    "jobs": [
      {
        "id": "b5e32f2a-5afd-48af-9712-867c20edf245",
        "name": "Mission Control Phase 1 heartbeat (main enforcer)",
        "schedule": "*/30 * * * * America/Denver",
        "enabled": true
      },
      {
        "id": "ad3c5d86-11e7-4dc4-9cb1-2024dd4d820c",
        "name": "Mission Control Phase 1 heartbeat (discord visibility)",
        "schedule": "5,35 * * * * America/Denver",
        "enabled": true
      },
      {
        "id": "dc9aea50-c7a7-4c66-a7df-7e349ff77d52",
        "name": "Mission Control Phase 2 autonomous loop (armed, disabled)",
        "schedule": "every 30m",
        "enabled": false
      }
    ]
  },
  "rules": {
    "allowOnly": [
      "code",
      "copy",
      "mission-control"
    ],
    "forbid": [
      "non-mission proactive loops",
      "image generation",
      "audio generation",
      "video generation",
      "outreach",
      "account creation"
    ]
  }
}
